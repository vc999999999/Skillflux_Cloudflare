---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE } from "../config";
import { absoluteUrl } from "../lib/content";
import { DEFAULT_LANGUAGE, getAlternateLanguagePath, getPageCopy, type Language } from "../lib/i18n";
import "../styles/global.css";

type Props = {
  lang?: Language;
  title?: string;
  description?: string;
  canonicalPath?: string;
  jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
  pageClass?: string;
};

const {
  lang = DEFAULT_LANGUAGE,
  title,
  description,
  canonicalPath = Astro.url.pathname,
  jsonLd,
  pageClass = ""
} = Astro.props;
const copy = getPageCopy(lang);
const pageDescription = description ?? copy.siteDescription;
const pageTitle = title ? `${title} | ${SITE.name}` : `${SITE.name} | ${copy.titleSuffix}`;
const canonical = absoluteUrl(canonicalPath);
const jsonLdItems = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const zhAlternate = absoluteUrl(getAlternateLanguagePath(Astro.url.pathname, "zh"));
const enAlternate = absoluteUrl(getAlternateLanguagePath(Astro.url.pathname, "en"));
const ogImage = absoluteUrl("/og.png");
const organizationJsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: SITE.name,
  alternateName: SITE.shortName,
  url: SITE.url,
  logo: absoluteUrl("/skillflux-mark.svg"),
  description: SITE.description,
  sameAs: [SITE.repoUrl]
};
---

<!doctype html>
<html lang={copy.htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="robots" content="index, follow" />
    {SITE.verification.google && <meta name="google-site-verification" content={SITE.verification.google} />}
    {SITE.verification.bing && <meta name="msvalidate.01" content={SITE.verification.bing} />}
    {SITE.verification.yandex && <meta name="yandex-verification" content={SITE.verification.yandex} />}
    {SITE.verification.baidu && <meta name="baidu-site-verification" content={SITE.verification.baidu} />}
    {SITE.verification.sogou && <meta name="sogou_site_verification" content={SITE.verification.sogou} />}
    {SITE.verification.so360 && <meta name="360-site-verification" content={SITE.verification.so360} />}
    {SITE.verification.shenma && <meta name="shenma-site-verification" content={SITE.verification.shenma} />}
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="zh-CN" href={zhAlternate} />
    <link rel="alternate" hreflang="en" href={enAlternate} />
    <link rel="alternate" hreflang="x-default" href={zhAlternate} />
    <link rel="alternate" type="application/rss+xml" title={`${SITE.name} RSS`} href={absoluteUrl("/feed.xml")} />
    <link rel="icon" href="/skillflux-mark.svg" type="image/svg+xml" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={SITE.name} />
    <meta property="og:locale" content={copy.locale === "en" ? "en_US" : "zh_CN"} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImage} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(organizationJsonLd)} />
    {jsonLdItems.map((item) => <script is:inline type="application/ld+json" set:html={JSON.stringify(item)} />)}
  </head>
  <body class={pageClass}>
    <Header lang={lang} currentPath={Astro.url.pathname} />
    <slot />
    <Footer lang={lang} />
    {SITE.cfBeaconToken && (
      <script
        is:inline
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={JSON.stringify({ token: SITE.cfBeaconToken })}
      />
    )}
  </body>
</html>
