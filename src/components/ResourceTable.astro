---
import type { Site } from "../lib/content";
import { getCategories } from "../lib/content";
import {
  DEFAULT_LANGUAGE,
  getPageCopy,
  getSiteCopy,
  localizePath,
  translateCategory,
  translatePricing,
  translateRegion,
  translateTrust,
  type Language
} from "../lib/i18n";

type Props = {
  sites: Site[];
  showControls?: boolean;
  heading?: string;
  compact?: boolean;
  lang?: Language;
};

const { sites, showControls = false, heading, compact = false, lang = DEFAULT_LANGUAGE } = Astro.props;
const copy = getPageCopy(lang);
const resolvedHeading = heading ?? (lang === "zh" ? "资源目录" : "Resource directory");
const categories = getCategories();
const categoryLabelBySlug = new Map(categories.map((category) => [category.slug, category.label]));

const regionOrder = ["cn", "global"];
const regions = regionOrder.filter((region) => sites.some((site) => site.region === region));
const trustOrder = ["high", "medium", "emerging"];
const trustLevels = trustOrder.filter((level) => sites.some((site) => site.trustLevel === level));
---

<section
  class:list={["resource-table-shell", compact && "is-compact"]}
  data-directory={showControls ? "true" : undefined}
  data-count-suffix={copy.resource.countSuffix}
>
  <div class="section-heading-row">
    <div>
      <p class="eyebrow"><span></span> {copy.resource.tableEyebrow}</p>
      <h2>{resolvedHeading}</h2>
    </div>
    <p class="section-note">{copy.resource.tableNote}</p>
  </div>

  {showControls && (
    <div class="directory-controls">
      <label class="search-box">
        <span>{copy.resource.searchLabel}</span>
        <input type="search" data-directory-search placeholder={copy.resource.searchPlaceholder} autocomplete="off" />
      </label>
      <div class="filter-buttons is-primary" role="group" aria-label={copy.resource.categoryLabel}>
        <button type="button" data-category-filter="all" aria-pressed="true">{copy.resource.all}</button>
        {categories.map((category) => (
          <button type="button" data-category-filter={category.slug} aria-pressed="false">
            {translateCategory(category.slug, category.label, lang)}
            <small>{category.count}</small>
          </button>
        ))}
      </div>
      <div class="filter-rows">
        <div class="filter-buttons is-secondary" role="group" aria-label={copy.resource.regionLabel}>
          <span class="filter-tag">{copy.resource.regionLabel}</span>
          <button type="button" data-region-filter="all" aria-pressed="true">{copy.resource.all}</button>
          {regions.map((region) => (
            <button type="button" data-region-filter={region} aria-pressed="false">{translateRegion(region, lang)}</button>
          ))}
        </div>
        <div class="filter-buttons is-secondary" role="group" aria-label={copy.resource.trustLabel}>
          <span class="filter-tag">{copy.resource.trustLabel}</span>
          <button type="button" data-trust-filter="all" aria-pressed="true">{copy.resource.all}</button>
          {trustLevels.map((level) => (
            <button type="button" data-trust-filter={level} aria-pressed="false">{translateTrust(level, lang)}</button>
          ))}
        </div>
      </div>
      <span class="result-count" data-result-count>{sites.length} {copy.resource.countSuffix}</span>
    </div>
  )}

  <div class="resource-table" role="table" aria-label={resolvedHeading}>
    <div class="resource-row table-head" role="row">
      <span>{copy.resource.tableHeaders.number}</span>
      <span>{copy.resource.tableHeaders.resource}</span>
      <span>{copy.resource.tableHeaders.source}</span>
      <span>{copy.resource.tableHeaders.locale}</span>
      <span>{copy.resource.tableHeaders.trust}</span>
      <span></span>
    </div>
    {sites.map((site, index) => {
      const siteCopy = getSiteCopy(site, lang);
      const searchable = [
        siteCopy.name,
        siteCopy.tagline,
        siteCopy.summary,
        siteCopy.aiSummary,
        siteCopy.type,
        siteCopy.tags.join(" "),
        site.tags.join(" ")
      ].join(" ").toLowerCase();
      const categoryLabel = translateCategory(site.category, categoryLabelBySlug.get(site.category) ?? site.category, lang);
      return (
        <a
          class="resource-row"
          role="row"
          href={localizePath(`/site/${site.slug}/`, lang)}
          data-site-row
          data-category={site.category}
          data-region={site.region}
          data-trust={site.trustLevel}
          data-search={searchable}
        >
          <span class="resource-number">{String(index + 1).padStart(2, "0")}</span>
          <span class="resource-name-cell">
            <strong>{siteCopy.name}</strong>
            {site.recommended && <em>{copy.resource.recommended}</em>}
            <small>{siteCopy.tagline}</small>
            <code>{site.displayUrl}</code>
          </span>
          <span>
            <strong>{categoryLabel}</strong>
            <small>{siteCopy.scale}</small>
          </span>
          <span>
            <strong>{translateRegion(site.region, lang)}</strong>
            <small>{translatePricing(site.pricing, lang)}</small>
          </span>
          <span>
            <span class:list={["trust-chip", `is-${site.trustLevel}`]}>{translateTrust(site.trustLevel, lang)}</span>
          </span>
          <span class="row-arrow" aria-hidden="true">↗</span>
        </a>
      );
    })}
  </div>

  {showControls && (
    <script is:inline>
      const directoryRoot = document.querySelector('[data-directory="true"]');
      if (directoryRoot) {
        const input = directoryRoot.querySelector("[data-directory-search]");
        const rows = Array.from(directoryRoot.querySelectorAll("[data-site-row]"));
        const count = directoryRoot.querySelector("[data-result-count]");
        const countSuffix = directoryRoot.getAttribute("data-count-suffix") || "条";

        // Each facet: data attribute on rows + button attribute + URL param.
        const facets = [
          { row: "data-category", btn: "data-category-filter", param: "category", active: "all" },
          { row: "data-region", btn: "data-region-filter", param: "region", active: "all" },
          { row: "data-trust", btn: "data-trust-filter", param: "trust", active: "all" }
        ];

        const updateRows = () => {
          const query = (input?.value || "").trim().toLowerCase();
          let visible = 0;
          rows.forEach((row) => {
            const haystack = row.getAttribute("data-search") || "";
            const matchesFacets = facets.every(
              (facet) => facet.active === "all" || (row.getAttribute(facet.row) || "") === facet.active
            );
            const matchesSearch = !query || haystack.includes(query);
            const shouldShow = matchesFacets && matchesSearch;
            row.hidden = !shouldShow;
            if (shouldShow) visible += 1;
          });
          if (count) count.textContent = `${visible} ${countSuffix}`;
        };

        const params = new URLSearchParams(window.location.search);
        facets.forEach((facet) => {
          facet.buttons = Array.from(directoryRoot.querySelectorAll(`[${facet.btn}]`));
          const sync = () =>
            facet.buttons.forEach((button) =>
              button.setAttribute("aria-pressed", String(button.getAttribute(facet.btn) === facet.active))
            );
          const initial = params.get(facet.param);
          if (initial && facet.buttons.some((button) => button.getAttribute(facet.btn) === initial)) {
            facet.active = initial;
            sync();
          }
          facet.buttons.forEach((button) => {
            button.addEventListener("click", () => {
              facet.active = button.getAttribute(facet.btn) || "all";
              sync();
              updateRows();
            });
          });
        });

        input?.addEventListener("input", updateRows);
        updateRows();
      }
    </script>
  )}
</section>
