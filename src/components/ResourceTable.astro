---
import type { Site } from "../lib/content";
import { getPopularTags } from "../lib/content";
import {
  DEFAULT_LANGUAGE,
  getPageCopy,
  getSiteCopy,
  localizePath,
  translateTag,
  type Language
} from "../lib/i18n";

type Props = {
  sites: Site[];
  showControls?: boolean;
  heading?: string;
  compact?: boolean;
  lang?: Language;
};

const { sites, showControls = false, heading, compact = false, lang = DEFAULT_LANGUAGE } = Astro.props;
const copy = getPageCopy(lang);
const resolvedHeading = heading ?? (lang === "zh" ? "资源目录" : "Resource directory");
const labels = getPopularTags(18);
---

<section
  class:list={["resource-table-shell", compact && "is-compact"]}
  data-directory={showControls ? "true" : undefined}
  data-count-suffix={copy.resource.countSuffix}
>
  <div class="section-heading-row">
    <div>
      <p class="eyebrow"><span></span> {copy.resource.tableEyebrow}</p>
      <h2>{resolvedHeading}</h2>
    </div>
    <p class="section-note">{copy.resource.tableNote}</p>
  </div>

  {showControls && (
    <div class="directory-controls" aria-label={copy.resource.filterLabel}>
      <label class="search-box">
        <span>{copy.resource.searchLabel}</span>
        <input type="search" data-directory-search placeholder={copy.resource.searchPlaceholder} autocomplete="off" />
      </label>
      <div class="filter-buttons" role="group" aria-label={copy.resource.filterLabel}>
        <button type="button" data-filter="all" aria-pressed="true">{copy.resource.all}</button>
        {labels.map((label) => (
          <button type="button" data-filter={label.tag} aria-pressed="false">{translateTag(label.tag, lang)}</button>
        ))}
      </div>
      <span class="result-count" data-result-count>{sites.length} {copy.resource.countSuffix}</span>
    </div>
  )}

  <div class="resource-table" role="table" aria-label={resolvedHeading}>
    <div class="resource-row table-head" role="row">
      <span>{copy.resource.tableHeaders.number}</span>
      <span>{copy.resource.tableHeaders.resource}</span>
      <span>{copy.resource.tableHeaders.type}</span>
      <span>{copy.resource.tableHeaders.scale}</span>
      <span>{copy.resource.tableHeaders.ai}</span>
      <span></span>
    </div>
    {sites.map((site, index) => {
      const siteCopy = getSiteCopy(site, lang);
      const searchable = [
        siteCopy.name,
        siteCopy.tagline,
        siteCopy.summary,
        siteCopy.aiSummary,
        siteCopy.type,
        siteCopy.scale,
        siteCopy.tags.join(" "),
        site.tags.join(" ")
      ].join(" ").toLowerCase();
      return (
        <a
          class="resource-row"
          role="row"
          href={localizePath(`/site/${site.slug}/`, lang)}
          data-site-row
          data-labels={site.tags.join("|||")}
          data-search={searchable}
        >
          <span class="resource-number">{String(index + 1).padStart(2, "0")}</span>
          <span class="resource-name-cell">
            <strong>{siteCopy.name}</strong>
            {site.recommended && <em>{copy.resource.recommended}</em>}
            <small>{siteCopy.tagline}</small>
            <code>{site.displayUrl}</code>
          </span>
          <span>
            <strong>{siteCopy.type}</strong>
            <small>{siteCopy.tags.slice(0, 4).join(" · ")} · {site.language.join("/")}</small>
          </span>
          <span>{siteCopy.scale}</span>
          <span>{siteCopy.aiSummary}</span>
          <span class="row-arrow" aria-hidden="true">↗</span>
        </a>
      );
    })}
  </div>

  {showControls && (
    <script is:inline>
      const directoryRoot = document.querySelector('[data-directory="true"]');
      if (directoryRoot) {
        const input = directoryRoot.querySelector("[data-directory-search]");
        const buttons = Array.from(directoryRoot.querySelectorAll("[data-filter]"));
        const rows = Array.from(directoryRoot.querySelectorAll("[data-site-row]"));
        const count = directoryRoot.querySelector("[data-result-count]");
        const countSuffix = directoryRoot.getAttribute("data-count-suffix") || "条";
        let activeFilter = "all";

        const updateRows = () => {
          const query = (input?.value || "").trim().toLowerCase();
          let visible = 0;
          rows.forEach((row) => {
            const labels = (row.getAttribute("data-labels") || "").split("|||");
            const haystack = row.getAttribute("data-search") || "";
            const matchesFilter = activeFilter === "all" || labels.includes(activeFilter);
            const matchesSearch = !query || haystack.includes(query);
            const shouldShow = matchesFilter && matchesSearch;
            row.hidden = !shouldShow;
            if (shouldShow) visible += 1;
          });
          if (count) count.textContent = `${visible} ${countSuffix}`;
        };

        const initialLabel = new URLSearchParams(window.location.search).get("label");
        if (initialLabel && buttons.some((button) => button.getAttribute("data-filter") === initialLabel)) {
          activeFilter = initialLabel;
          buttons.forEach((button) => button.setAttribute("aria-pressed", String(button.getAttribute("data-filter") === activeFilter)));
        }

        buttons.forEach((button) => {
          button.addEventListener("click", () => {
            activeFilter = button.getAttribute("data-filter") || "all";
            buttons.forEach((item) => item.setAttribute("aria-pressed", String(item === button)));
            updateRows();
          });
        });

        input?.addEventListener("input", updateRows);
        updateRows();
      }
    </script>
  )}
</section>
