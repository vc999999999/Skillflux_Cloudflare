---
import { ENDPOINTS, SITE } from "../config";
import { getPopularTags } from "../lib/content";
import { DEFAULT_LANGUAGE, getPageCopy, localizePath, translateTag, type Language } from "../lib/i18n";

type Props = {
  lang?: Language;
};

const { lang = DEFAULT_LANGUAGE } = Astro.props;
const copy = getPageCopy(lang);
const labels = getPopularTags(6);
---

<footer class="site-footer">
  <div class="footer-grid">
    <div>
      <a class="footer-brand" href={localizePath("/", lang)}>
        <span>技流</span>
        <small>SkillFlux</small>
      </a>
      <p>{copy.footer.summary}</p>
    </div>
    <div>
      <h2>{copy.footer.labels}</h2>
      <ul>
        {labels.map((label) => (
          <li><a href={`${localizePath("/directory/", lang)}?label=${encodeURIComponent(label.tag)}`}>{translateTag(label.tag, lang)} <span>{label.count}</span></a></li>
        ))}
      </ul>
    </div>
    <div>
      <h2>{copy.footer.forAi}</h2>
      <ul>
        {ENDPOINTS.map((endpoint) => (
          <li><a href={endpoint.path}>{endpoint.path}</a></li>
        ))}
      </ul>
    </div>
    <div>
      <h2>{copy.footer.brand}</h2>
      <ul>
        <li><a href={localizePath("/directory/", lang)}>{copy.footer.directory}</a></li>
        <li><a href={SITE.packUrl} rel="noopener noreferrer">{copy.footer.pack}</a></li>
        <li><a href={SITE.repoUrl} rel="noopener noreferrer">GitHub</a></li>
      </ul>
    </div>
  </div>
  <div class="footer-bottom">
    <span>{copy.footer.copyrightNote}</span>
    <span>© 2026 技流 SkillFlux</span>
  </div>
</footer>
