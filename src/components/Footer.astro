---
import { ENDPOINTS, SITE } from "../config";
import { getCategories } from "../lib/content";
import { DEFAULT_LANGUAGE, getPageCopy, localizePath, translateCategory, type Language } from "../lib/i18n";

type Props = {
  lang?: Language;
};

const { lang = DEFAULT_LANGUAGE } = Astro.props;
const copy = getPageCopy(lang);
const categories = getCategories();
---

<footer class="site-footer">
  <div class="footer-grid">
    <div>
      <a class="footer-brand" href={localizePath("/", lang)}>
        <span>技流</span>
        <small>SkillFlux</small>
      </a>
      <p>{copy.footer.summary}</p>
    </div>
    <div>
      <h2>{copy.footer.labels}</h2>
      <ul>
        {categories.map((category) => (
          <li><a href={localizePath(`/category/${category.slug}/`, lang)}>{translateCategory(category.slug, category.label, lang)} <span>{category.count}</span></a></li>
        ))}
      </ul>
    </div>
    <div>
      <h2>{copy.footer.forAi}</h2>
      <ul>
        {ENDPOINTS.map((endpoint) => (
          <li><a href={endpoint.path}>{endpoint.path}</a></li>
        ))}
      </ul>
    </div>
    <div>
      <h2>{copy.footer.brand}</h2>
      <ul>
        <li><a href={localizePath("/directory/", lang)}>{copy.footer.directory}</a></li>
        <li><a href={localizePath("/guides/", lang)}>{copy.breadcrumb.guides}</a></li>
        <li><a href={localizePath("/", lang)}>{copy.footer.pack}</a></li>
        <li><a href={SITE.repoUrl} rel="noopener noreferrer">GitHub</a></li>
      </ul>
    </div>
  </div>
  <div class="footer-bottom">
    <span>{copy.footer.copyrightNote}</span>
    <span>© 2026 砚垚信息科技(上海)有限公司</span>
  </div>
</footer>
