---
import { SITE } from "../config";
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  absoluteUrl,
  getDirectoryStats,
  getFeaturedSites,
  getCategories,
  getTagIndex
} from "../lib/content";
import {
  DEFAULT_LANGUAGE,
  getPageCopy,
  localizePath,
  translateCategory,
  type Language
} from "../lib/i18n";
import { getGuides } from "../lib/guides";
import ResourceCard from "./ResourceCard.astro";
import PackCta from "./PackCta.astro";

type Props = {
  lang?: Language;
};

const { lang = DEFAULT_LANGUAGE } = Astro.props;
const copy = getPageCopy(lang);
const stats = getDirectoryStats();
const featured = getFeaturedSites(8);
const categories = getCategories();
const tags = getTagIndex().slice(0, 18);
const guides = getGuides();
const canonicalPath = localizePath("/", lang);
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: SITE.name,
    url: absoluteUrl(canonicalPath),
    description: copy.siteDescription,
    inLanguage: copy.locale
  },
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    name: lang === "zh" ? "SkillFlux featured skill/MCP resources" : "SkillFlux featured skill and MCP resources",
    itemListElement: featured.map((site, index) => ({
      "@type": "ListItem",
      position: index + 1,
      url: absoluteUrl(localizePath(`/site/${site.slug}/`, lang)),
      name: site.name
    }))
  }
];
---

<BaseLayout lang={lang} canonicalPath={canonicalPath} jsonLd={jsonLd}>
  <main>
    <section class="hero" id="top">
      <div>
        <p class="eyebrow"><span></span> {copy.home.eyebrow}</p>
        <h1>技流<small>SkillFlux</small></h1>
        <p class="hero-lede">{copy.home.heroLead}</p>
        <div class="hero-actions">
          <a class="button primary" href={localizePath("/directory/", lang)}>{copy.home.browseDirectory}</a>
          <a class="button secondary" href="/llms.txt">{copy.home.readForAi}</a>
        </div>
        <div class="hero-stats" aria-label={copy.home.statsLabel}>
          <div>
            <span class="stat-kicker">01</span>
            <strong>{stats.resourceCount}</strong>
            <span class="stat-label">{copy.home.stats.resources}</span>
          </div>
          <div>
            <span class="stat-kicker">02</span>
            <strong>{stats.labelCount}</strong>
            <span class="stat-label">{copy.home.stats.labels}</span>
          </div>
          <div>
            <span class="stat-kicker">03</span>
            <strong>{stats.featuredCount}</strong>
            <span class="stat-label">{copy.home.stats.featured}</span>
          </div>
          <div>
            <span class="stat-kicker">04</span>
            <strong>{stats.updatedAt}</strong>
            <span class="stat-label">{copy.home.stats.updated}</span>
          </div>
        </div>
      </div>

      <aside class="hero-panel" aria-label={copy.home.panelAria}>
        <div class="install-head">
          <span class="install-label">{copy.home.panelTitle} · {copy.home.panelVersion}</span>
          <div class="hero-install">
            <code>{copy.cta.command}</code>
            <button
              type="button"
              class="copy-btn"
              data-copy={copy.cta.command}
              aria-label={copy.cta.copy}
            >
              {copy.cta.copy}
            </button>
          </div>
          <p class="install-tagline">{copy.home.panelTagline}</p>
        </div>
        <dl class="ledger-list">
          <div><dt>{copy.home.ledger.install}</dt><dd>{copy.home.ledger.installValue}</dd></div>
          <div><dt>{copy.home.ledger.scope}</dt><dd>{copy.home.ledger.scopeValue}</dd></div>
          <div><dt>{copy.home.ledger.maintenance}</dt><dd>{copy.home.ledger.maintenanceValue}</dd></div>
          <div><dt>{copy.home.ledger.adapters}</dt><dd>{copy.home.ledger.adaptersValue}</dd></div>
        </dl>
        <p class="hero-install-note">{copy.cta.note}</p>
      </aside>
    </section>

    <section class="home-section">
      <div class="section-heading-row">
        <div>
          <p class="eyebrow"><span></span> {copy.home.featuredEyebrow}</p>
          <h2>{copy.home.featuredTitle}</h2>
        </div>
        <p class="section-note">{copy.home.featuredNote}</p>
      </div>
      <div class="card-grid">
        {featured.map((site, index) => <ResourceCard site={site} index={index} lang={lang} />)}
      </div>
    </section>

    <PackCta lang={lang} />

    <section class="home-section">
      <div class="section-heading-row">
        <div>
          <p class="eyebrow"><span></span> {copy.home.labelsEyebrow}</p>
          <h2>{copy.home.labelsTitle}</h2>
        </div>
        <p class="section-note">{copy.home.labelsNote}</p>
      </div>
      <div class="category-grid">
        {categories.map((category) => {
          const displayLabel = translateCategory(category.slug, category.label, lang);
          return (
            <a class="category-card" href={localizePath(`/category/${category.slug}/`, lang)}>
              <div class="category-card-top">
                <span class="category-count">{String(category.count).padStart(2, "0")}</span>
                <span>{copy.home.labelCardKicker}</span>
              </div>
              <strong>{displayLabel}</strong>
              <p>{copy.home.labelCardDescription(displayLabel)}</p>
            </a>
          );
        })}
      </div>
    </section>

    <section class="home-section">
      <div class="section-heading-row">
        <div>
          <p class="eyebrow"><span></span> Tags</p>
          <h2>{copy.collections.browseTagsTitle}</h2>
        </div>
        <p class="section-note">{copy.collections.browseTagsNote}</p>
      </div>
      <div class="tag-cloud">
        {tags.map((entry) => (
          <a class="tag-chip" href={localizePath(`/tag/${entry.slug}/`, lang)}>
            {entry.tag}<small>{entry.count}</small>
          </a>
        ))}
      </div>
    </section>

    <section class="home-section">
      <div class="section-heading-row">
        <div>
          <p class="eyebrow"><span></span> {copy.guidesPage.eyebrow}</p>
          <h2>{copy.guidesPage.indexTitle}</h2>
        </div>
        <a class="section-note-link" href={localizePath("/guides/", lang)}>{copy.guidesPage.readMore} →</a>
      </div>
      <div class="home-guide-grid">
        {guides.map((guide) => (
          <a class="home-guide-card" href={localizePath(`/guides/${guide.slug}/`, lang)}>
            <h3>{guide.title[lang]}</h3>
            <p>{guide.description[lang]}</p>
          </a>
        ))}
      </div>
    </section>

  </main>
</BaseLayout>

<style>
  .install-head {
    padding: 24px;
    background: var(--ink);
    color: var(--paper);
  }

  .install-tagline {
    margin: 14px 0 0;
    font-size: 0.84rem;
    line-height: 1.55;
    color: rgba(244, 241, 232, 0.66);
  }

  .hero-panel .ledger-list {
    padding: 8px 20px;
  }

  .install-label {
    display: block;
    margin-bottom: 14px;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    opacity: 0.7;
  }

  .hero-install {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 14px;
    background: rgba(244, 241, 232, 0.08);
    border: 1px solid rgba(244, 241, 232, 0.28);
    border-radius: 8px;
  }

  .hero-install code {
    flex: 1;
    min-width: 0;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--paper);
    white-space: nowrap;
    overflow-x: auto;
  }

  .hero-install code::before {
    content: "$ ";
    opacity: 0.5;
  }

  .copy-btn {
    flex-shrink: 0;
    padding: 6px 12px;
    background: var(--paper);
    color: var(--ink);
    border: none;
    border-radius: 6px;
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    font-family: var(--font-body);
    transition: opacity 0.15s ease;
  }

  .copy-btn:hover {
    opacity: 0.85;
  }

  .copy-btn.copied {
    background: var(--green);
    color: var(--paper);
  }

  .hero-install-note {
    margin: 0;
    margin-top: auto;
    padding: 16px 20px;
    border-top: 1px solid var(--line);
    font-size: 0.82rem;
    color: var(--muted);
  }

  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .tag-chip {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    border: 1px solid var(--line);
    border-radius: 999px;
    font-size: 0.88rem;
    color: var(--ink);
    text-decoration: none;
    transition: border-color 0.15s ease, background 0.15s ease;
  }

  .tag-chip:hover {
    border-color: var(--ink);
    background: var(--paper);
  }

  .tag-chip small {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--muted);
  }

  .section-note-link {
    color: var(--green);
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
  }

  .home-guide-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 16px;
  }

  .home-guide-card {
    display: block;
    padding: 22px;
    border: 1px solid var(--line-strong);
    background: var(--paper-strong);
    text-decoration: none;
    color: var(--ink);
    transition: transform 0.15s ease;
  }

  .home-guide-card:hover {
    transform: translateY(-2px);
  }

  .home-guide-card h3 {
    margin: 0 0 10px;
    font-size: 1.15rem;
    line-height: 1.4;
  }

  .home-guide-card p {
    margin: 0;
    color: var(--muted);
    line-height: 1.6;
    font-size: 0.92rem;
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>(".hero-panel .copy-btn").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const text = btn.getAttribute("data-copy") ?? "";
      try {
        await navigator.clipboard.writeText(text);
        const original = btn.textContent;
        btn.textContent = "✓";
        btn.classList.add("copied");
        setTimeout(() => {
          btn.textContent = original;
          btn.classList.remove("copied");
        }, 1500);
      } catch {
        // Clipboard unavailable (e.g. non-secure context) — no-op.
      }
    });
  });
</script>
