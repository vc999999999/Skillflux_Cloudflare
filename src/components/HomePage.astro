---
import { SITE } from "../config";
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  absoluteUrl,
  getDirectoryStats,
  getFeaturedSites,
  getCategories
} from "../lib/content";
import {
  DEFAULT_LANGUAGE,
  getPageCopy,
  localizePath,
  translateCategory,
  type Language
} from "../lib/i18n";
import ResourceCard from "./ResourceCard.astro";
import PackCta from "./PackCta.astro";

type Props = {
  lang?: Language;
};

const { lang = DEFAULT_LANGUAGE } = Astro.props;
const copy = getPageCopy(lang);
const stats = getDirectoryStats();
const featured = getFeaturedSites(8);
const categories = getCategories();
const canonicalPath = localizePath("/", lang);
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: SITE.name,
    url: absoluteUrl(canonicalPath),
    description: copy.siteDescription,
    inLanguage: copy.locale
  },
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    name: lang === "zh" ? "SkillFlux featured skill/MCP resources" : "SkillFlux featured skill and MCP resources",
    itemListElement: featured.map((site, index) => ({
      "@type": "ListItem",
      position: index + 1,
      url: absoluteUrl(localizePath(`/site/${site.slug}/`, lang)),
      name: site.name
    }))
  }
];
---

<BaseLayout lang={lang} canonicalPath={canonicalPath} jsonLd={jsonLd}>
  <main>
    <section class="hero" id="top">
      <div>
        <p class="eyebrow"><span></span> {copy.home.eyebrow}</p>
        <h1>技流<small>SkillFlux</small></h1>
        <p class="hero-lede">{copy.home.heroLead}</p>
        <div class="hero-actions">
          <a class="button primary" href={localizePath("/directory/", lang)}>{copy.home.browseDirectory}</a>
          <a class="button secondary" href="/llms.txt">{copy.home.readForAi}</a>
        </div>
        <div class="hero-stats" aria-label={copy.home.statsLabel}>
          <div>
            <span class="stat-kicker">01</span>
            <strong>{stats.resourceCount}</strong>
            <span class="stat-label">{copy.home.stats.resources}</span>
          </div>
          <div>
            <span class="stat-kicker">02</span>
            <strong>{stats.labelCount}</strong>
            <span class="stat-label">{copy.home.stats.labels}</span>
          </div>
          <div>
            <span class="stat-kicker">03</span>
            <strong>{stats.featuredCount}</strong>
            <span class="stat-label">{copy.home.stats.featured}</span>
          </div>
          <div>
            <span class="stat-kicker">04</span>
            <strong>{stats.updatedAt}</strong>
            <span class="stat-label">{copy.home.stats.updated}</span>
          </div>
        </div>
      </div>

      <aside class="hero-panel" aria-label={copy.home.panelAria}>
        <div class="install-head">
          <span class="install-label">{copy.home.panelTitle} · {copy.home.panelVersion}</span>
          <div class="hero-install">
            <code>{copy.cta.command}</code>
            <button
              type="button"
              class="copy-btn"
              data-copy={copy.cta.command}
              aria-label={copy.cta.copy}
            >
              {copy.cta.copy}
            </button>
          </div>
        </div>
        <dl class="ledger-list">
          <div><dt>{copy.home.ledger.directory}</dt><dd>{stats.resourceCount} {copy.home.ledger.resourcesSuffix}</dd></div>
          <div><dt>{copy.home.ledger.install}</dt><dd>{copy.home.ledger.installValue}</dd></div>
          <div><dt>{copy.home.ledger.maintenance}</dt><dd>{copy.home.ledger.maintenanceValue}</dd></div>
          <div><dt>{copy.home.ledger.adapters}</dt><dd>{copy.home.ledger.adaptersValue}</dd></div>
        </dl>
        <p class="hero-install-note">{copy.cta.note}</p>
      </aside>
    </section>

    <section class="home-section">
      <div class="section-heading-row">
        <div>
          <p class="eyebrow"><span></span> {copy.home.featuredEyebrow}</p>
          <h2>{copy.home.featuredTitle}</h2>
        </div>
        <p class="section-note">{copy.home.featuredNote}</p>
      </div>
      <div class="card-grid">
        {featured.map((site, index) => <ResourceCard site={site} index={index} lang={lang} />)}
      </div>
    </section>

    <PackCta lang={lang} />

    <section class="home-section">
      <div class="section-heading-row">
        <div>
          <p class="eyebrow"><span></span> {copy.home.labelsEyebrow}</p>
          <h2>{copy.home.labelsTitle}</h2>
        </div>
        <p class="section-note">{copy.home.labelsNote}</p>
      </div>
      <div class="category-grid">
        {categories.map((category) => {
          const displayLabel = translateCategory(category.slug, category.label, lang);
          return (
            <a class="category-card" href={`${localizePath("/directory/", lang)}?category=${encodeURIComponent(category.slug)}`}>
              <div class="category-card-top">
                <span class="category-count">{String(category.count).padStart(2, "0")}</span>
                <span>{copy.home.labelCardKicker}</span>
              </div>
              <strong>{displayLabel}</strong>
              <p>{copy.home.labelCardDescription(displayLabel)}</p>
            </a>
          );
        })}
      </div>
    </section>

  </main>
</BaseLayout>

<style>
  .install-head {
    padding: 24px;
    background: var(--ink);
    color: var(--paper);
  }

  .install-label {
    display: block;
    margin-bottom: 14px;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    opacity: 0.7;
  }

  .hero-install {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 14px;
    background: rgba(244, 241, 232, 0.08);
    border: 1px solid rgba(244, 241, 232, 0.28);
    border-radius: 8px;
  }

  .hero-install code {
    flex: 1;
    min-width: 0;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--paper);
    white-space: nowrap;
    overflow-x: auto;
  }

  .hero-install code::before {
    content: "$ ";
    opacity: 0.5;
  }

  .copy-btn {
    flex-shrink: 0;
    padding: 6px 12px;
    background: var(--paper);
    color: var(--ink);
    border: none;
    border-radius: 6px;
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    font-family: var(--font-body);
    transition: opacity 0.15s ease;
  }

  .copy-btn:hover {
    opacity: 0.85;
  }

  .copy-btn.copied {
    background: var(--green);
    color: var(--paper);
  }

  .hero-install-note {
    margin: 0;
    padding: 14px 20px 20px;
    font-size: 0.82rem;
    color: var(--muted);
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>(".hero-panel .copy-btn").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const text = btn.getAttribute("data-copy") ?? "";
      try {
        await navigator.clipboard.writeText(text);
        const original = btn.textContent;
        btn.textContent = "✓";
        btn.classList.add("copied");
        setTimeout(() => {
          btn.textContent = original;
          btn.classList.remove("copied");
        }, 1500);
      } catch {
        // Clipboard unavailable (e.g. non-secure context) — no-op.
      }
    });
  });
</script>
