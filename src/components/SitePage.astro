---
import { SITE } from "../config";
import BaseLayout from "../layouts/BaseLayout.astro";
import { absoluteUrl, getRelatedSites, getTagIndex, type Site } from "../lib/content";
import {
  DEFAULT_LANGUAGE,
  getPageCopy,
  getSiteCopy,
  localizePath,
  translatePricing,
  translateTrust,
  type Language
} from "../lib/i18n";
import ResourceTable from "./ResourceTable.astro";
import PackCta from "./PackCta.astro";
import Breadcrumb from "./Breadcrumb.astro";
import { translatePricing as pricingLabel } from "../lib/i18n";

type Props = {
  site: Site;
  lang?: Language;
};

const { site, lang = DEFAULT_LANGUAGE } = Astro.props;
const copy = getPageCopy(lang);
const siteCopy = getSiteCopy(site, lang);
const related = getRelatedSites(site, 4);
const description = `${siteCopy.tagline} ${siteCopy.summary}`;
const canonicalPath = localizePath(`/site/${site.slug}/`, lang);

const tagSlugByName = new Map(getTagIndex().map((entry) => [entry.tag, entry.slug]));
// Original zh tags map 1:1 (same order) to the localized siteCopy.tags.
const tagLinks = site.tags.map((tag, index) => ({
  label: siteCopy.tags[index] ?? tag,
  slug: tagSlugByName.get(tag)
}));

const breadcrumbItems = [
  { label: copy.breadcrumb.home, href: localizePath("/", lang) },
  { label: copy.breadcrumb.directory, href: localizePath("/directory/", lang) },
  { label: siteCopy.name }
];

// Editorial write-up (data is zh-primary). EN pages use the synthesized summary.
const introParagraphs =
  lang === "zh" && site.longSummary ? site.longSummary.split(/\n\n+/) : [siteCopy.summary];

const autoFaqs = [
  { q: copy.faq.whatIs(siteCopy.name), a: siteCopy.summary },
  { q: copy.faq.whoFor(siteCopy.name), a: `${siteCopy.aiSummary} ${copy.detail.positionText(siteCopy.name, siteCopy.tags.slice(0, 4).join(" / "))}`.trim() },
  { q: copy.faq.pricingQ(siteCopy.name), a: pricingLabel(site.pricing, lang) },
  { q: copy.faq.accessQ(siteCopy.name), a: copy.faq.accessA(siteCopy.name, site.canonicalUrl) }
];
const faqs = lang === "zh" && site.faqs && site.faqs.length > 0 ? site.faqs : autoFaqs;

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: `${siteCopy.name} - SkillFlux`,
    url: absoluteUrl(canonicalPath),
    description,
    inLanguage: copy.locale,
    datePublished: site.addedAt,
    dateModified: site.updatedAt,
    isPartOf: {
      "@type": "WebSite",
      name: SITE.name,
      url: SITE.url
    },
    about: {
      "@type": "Thing",
      name: siteCopy.name,
      url: site.canonicalUrl,
      description: siteCopy.summary
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: breadcrumbItems.map((crumb, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: crumb.label,
      ...(crumb.href ? { item: absoluteUrl(crumb.href) } : {})
    }))
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map((faq) => ({
      "@type": "Question",
      name: faq.q,
      acceptedAnswer: {
        "@type": "Answer",
        text: faq.a
      }
    }))
  }
];
---

<BaseLayout lang={lang} title={siteCopy.name} description={description} canonicalPath={canonicalPath} jsonLd={jsonLd}>
  <main class="page-shell">
    <article>
      <section class="detail-hero">
        <Breadcrumb items={breadcrumbItems} ariaLabel={copy.breadcrumb.home} />
        <div class="detail-hero-grid">
          <div>
            <p class="eyebrow"><span></span> {siteCopy.tags[0]}</p>
            <h1>{siteCopy.name}</h1>
            <p>{siteCopy.tagline}</p>
            <div class="detail-badges">
              {site.recommended && <span>{copy.resource.recommended}</span>}
              <span>{siteCopy.type}</span>
              <span>{siteCopy.scale}</span>
              <span>{site.language.join(" / ")}</span>
              <span>{translateTrust(site.trustLevel, lang)}</span>
            </div>
          </div>
          <aside class="detail-panel">
            <dl>
              <div><dt>{copy.detail.labels}</dt><dd>{siteCopy.tags.slice(0, 2).join(" / ")}</dd></div>
              <div><dt>{copy.detail.pricing}</dt><dd>{translatePricing(site.pricing, lang)}</dd></div>
              <div><dt>{copy.detail.status}</dt><dd>{site.status}</dd></div>
              <div><dt>{copy.detail.updated}</dt><dd>{site.updatedAt}</dd></div>
            </dl>
            <a class="button primary" href={site.canonicalUrl} rel="noopener noreferrer">{copy.detail.visit}</a>
          </aside>
        </div>
      </section>

      <section class="detail-grid">
        <div>
          <div class="prose-block">
            <h2>{copy.detail.intro}</h2>
            {introParagraphs.map((paragraph) => <p>{paragraph}</p>)}
          </div>
          <div class="prose-block">
            <h2>{copy.detail.aiRead}</h2>
            <p>{siteCopy.aiSummary}</p>
          </div>
          <div class="prose-block">
            <h2>{copy.detail.sourceLinks}</h2>
            <ul class="source-list">
              {site.sourceUrls.map((url) => (
                <li><a href={url} rel="noopener noreferrer">{new URL(url).hostname}</a></li>
              ))}
            </ul>
          </div>
        </div>
        <aside class="detail-side">
          <div class="side-box">
            <h2>{copy.detail.positioning}</h2>
            <p>{copy.detail.positionText(siteCopy.name, siteCopy.tags.slice(0, 4).join(" / "))}</p>
          </div>
          <div class="side-box">
            <h2>{copy.detail.tags}</h2>
            <div class="tag-list">
              {tagLinks.map((tag) =>
                tag.slug ? (
                  <a href={localizePath(`/tag/${tag.slug}/`, lang)}>{tag.label}</a>
                ) : (
                  <span>{tag.label}</span>
                )
              )}
            </div>
          </div>
          <div class="side-box">
            <h2>{copy.detail.machine}</h2>
            <p>{copy.detail.machineText}</p>
          </div>
        </aside>
      </section>

      <section class="detail-faq">
        <h2>{copy.faq.heading}</h2>
        <dl class="faq-list">
          {faqs.map((faq) => (
            <div class="faq-item">
              <dt>{faq.q}</dt>
              <dd>{faq.a}</dd>
            </div>
          ))}
        </dl>
      </section>
    </article>

    {related.length > 0 && <ResourceTable sites={related} heading={copy.detail.related} compact={true} lang={lang} />}

    <PackCta lang={lang} />
  </main>
</BaseLayout>
