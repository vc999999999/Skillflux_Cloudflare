---
import { SITE } from "../config";
import { DEFAULT_LANGUAGE, getAlternateLanguagePath, getPageCopy, localizePath, type Language } from "../lib/i18n";

type Props = {
  lang?: Language;
  currentPath?: string;
};

const { lang = DEFAULT_LANGUAGE, currentPath = "/" } = Astro.props;
const copy = getPageCopy(lang);
---

<header class="site-header">
  <div class="site-header-inner">
    <a class="brand-lockup" href={localizePath("/", lang)} aria-label={copy.nav.homeLabel}>
      <span class="brand-hanzi">技流</span>
      <span class="brand-latin">SkillFlux</span>
    </a>
    <nav class="main-nav" aria-label={lang === "zh" ? "主导航" : "Main navigation"}>
      <a href={localizePath("/directory/", lang)}>{copy.nav.directory}</a>
      <a href={`${localizePath("/directory/", lang)}?label=${encodeURIComponent("推荐")}`}>{copy.nav.recommended}</a>
      <a href="/llms.txt">{copy.nav.llms}</a>
      <a class="nav-pack" href={SITE.packUrl} rel="noopener noreferrer">{copy.nav.pack}</a>
      <div class="language-switcher" aria-label={copy.nav.languageLabel}>
        <a class:list={[lang === "zh" && "is-active"]} href={getAlternateLanguagePath(currentPath, "zh")} lang="zh-CN">中</a>
        <a class:list={[lang === "en" && "is-active"]} href={getAlternateLanguagePath(currentPath, "en")} lang="en">EN</a>
      </div>
    </nav>
  </div>
</header>
