---
import ResourceCard from "../components/ResourceCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { ENDPOINTS, SITE } from "../config";
import {
  absoluteUrl,
  getCategoriesWithCounts,
  getDirectoryStats,
  getFeaturedSites
} from "../lib/content";

const stats = getDirectoryStats();
const featured = getFeaturedSites(8);
const categories = getCategoriesWithCounts();
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: SITE.name,
    url: SITE.url,
    description: SITE.description,
    inLanguage: SITE.locale
  },
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    name: "SkillFlux featured skill/MCP resources",
    itemListElement: featured.map((site, index) => ({
      "@type": "ListItem",
      position: index + 1,
      url: absoluteUrl(`/site/${site.slug}/`),
      name: site.name
    }))
  }
];
---

<BaseLayout jsonLd={jsonLd}>
  <main>
    <section class="hero" id="top">
      <div>
        <p class="eyebrow"><span></span> skill / mcp ecosystem index</p>
        <h1>技流<small>SkillFlux</small></h1>
        <p class="hero-lede">
          一个面向开发者、Agent 重度用户和搜索爬虫的 skill/MCP 生态入口。把注册表、市场、官方仓库、社区榜单和 AI 可读索引放在一处，不再满网乱翻。
        </p>
        <div class="hero-actions">
          <a class="button primary" href="/directory/">浏览目录</a>
          <a class="button secondary" href="/llms.txt">给 AI 读取</a>
          <a class="button dark" href={SITE.packUrl} rel="noopener noreferrer">精装包入口</a>
        </div>
        <div class="hero-stats" aria-label="站点统计">
          <div>
            <strong>{stats.resourceCount}</strong>
            <span>首批高质量入口</span>
          </div>
          <div>
            <strong>{stats.categoryCount}</strong>
            <span>核心分类</span>
          </div>
          <div>
            <strong>{stats.featuredCount}</strong>
            <span>重点推荐</span>
          </div>
          <div>
            <strong>{stats.updatedAt}</strong>
            <span>最近更新</span>
          </div>
        </div>
      </div>

      <aside class="hero-panel" aria-label="SkillFlux 精装包">
        <img src="/skillflux-mark.svg" alt="技流 SkillFlux 品牌标识" width="640" height="420" />
        <div class="pack-ledger-header">
          <span>Deluxe Pack</span>
          <strong>v0.1</strong>
        </div>
        <dl class="ledger-list">
          <div><dt>目录</dt><dd>{stats.resourceCount} 个入口</dd></div>
          <div><dt>安装</dt><dd>一键 MCP</dd></div>
          <div><dt>维护</dt><dd>JSON 更新</dd></div>
          <div><dt>适配</dt><dd>Claude · Cursor · Codex</dd></div>
        </dl>
        <div class="pack-actions">
          <a class="button primary" href={SITE.packUrl} rel="noopener noreferrer">立即查看精装包</a>
          <a class="button secondary" href="/directory/">先看免费目录</a>
        </div>
      </aside>
    </section>

    <section class="home-section">
      <div class="section-heading-row">
        <div>
          <p class="eyebrow"><span></span> Featured</p>
          <h2>先从这些入口开始。</h2>
        </div>
        <p class="section-note">精选入口覆盖官方标准、MCP 注册表、市场和中文生态。每条都能进入详情页，再跳转原站。</p>
      </div>
      <div class="card-grid">
        {featured.map((site, index) => <ResourceCard site={site} index={index} />)}
      </div>
    </section>

    <section class="home-section">
      <div class="section-heading-row">
        <div>
          <p class="eyebrow"><span></span> Categories</p>
          <h2>按生态位置浏览。</h2>
        </div>
        <p class="section-note">MVP 用静态分类页保障 SEO 和无 JS 可读；目录页额外提供轻量即时筛选。</p>
      </div>
      <div class="category-grid">
        {categories.map((category) => (
          <a class="category-card" href={`/category/${category.slug}/`}>
            <div class="category-card-top">
              <span class="category-count">{String(category.count).padStart(2, "0")}</span>
              <span>{category.shortLabel}</span>
            </div>
            <strong>{category.label}</strong>
            <p>{category.description}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="ai-band" id="ai">
      <div class="ai-band-inner">
        <div class="section-heading-row">
          <div>
            <p class="eyebrow"><span></span> For Agents</p>
            <h2>让 AI 直接读懂整个目录。</h2>
          </div>
          <p class="section-note">所有机器可读文件都由同一份 JSON 生成，不依赖客户端 JavaScript。</p>
        </div>
        <div class="endpoint-grid">
          {ENDPOINTS.map((endpoint) => (
            <a class="endpoint-card" href={endpoint.path}>
              <code>{endpoint.path}</code>
              <strong>{endpoint.label}</strong>
              <p>{endpoint.description}</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="home-section pack-section" id="pack">
      <div class="pack-block">
        <p class="eyebrow"><span></span> SkillFlux Pack</p>
        <h2>导航免费，打包好的能力留给精装包。</h2>
        <p>
          目录负责发现和判断；精装包负责把常用 skill/MCP 能力整理成可安装、可维护、少踩坑的组合。MVP 先保留轻量入口和 UTM 链接，后续再接转化页。
        </p>
      </div>
      <aside class="pack-aside">
        <ul>
          <li><span>定位</span><strong>精选能力包</strong></li>
          <li><span>入口</span><strong>低干扰 CTA</strong></li>
          <li><span>统计</span><strong>UTM 外链</strong></li>
        </ul>
        <a class="button primary" href={SITE.packUrl} rel="noopener noreferrer">查看精装包</a>
      </aside>
    </section>
  </main>
</BaseLayout>
