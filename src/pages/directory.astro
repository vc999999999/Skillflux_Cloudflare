---
import ResourceTable from "../components/ResourceTable.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE } from "../config";
import { absoluteUrl, getCategoriesWithCounts, getDirectoryStats, getSites } from "../lib/content";

const sites = getSites();
const categories = getCategoriesWithCounts();
const stats = getDirectoryStats();
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "SkillFlux 完整目录",
  url: absoluteUrl("/directory/"),
  description: "SkillFlux 收录的 skill/MCP 生态入口完整目录。",
  isPartOf: {
    "@type": "WebSite",
    name: SITE.name,
    url: SITE.url
  },
  mainEntity: {
    "@type": "ItemList",
    numberOfItems: sites.length,
    itemListElement: sites.map((site, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: site.name,
      url: absoluteUrl(`/site/${site.slug}/`)
    }))
  }
};
---

<BaseLayout title="完整目录" description="浏览 SkillFlux 收录的 skill/MCP 注册表、市场、官方仓库、榜单和 MCP 入口。" canonicalPath="/directory/" jsonLd={jsonLd}>
  <main class="page-shell">
    <section class="page-hero">
      <div>
        <p class="eyebrow"><span></span> Directory</p>
        <h1 class="page-title">全网 skill/MCP 生态入口，一处看全。</h1>
        <p class="page-lede">按名称、标签和摘要即时筛选。静态 HTML 仍保留全部内容，搜索引擎和 AI 不需要执行 JS 也能读取。</p>
      </div>
      <aside class="page-meta-panel">
        <strong>{stats.resourceCount}</strong>
        <span>resources · {categories.length} categories · updated {stats.updatedAt}</span>
      </aside>
    </section>

    <ResourceTable sites={sites} showControls={true} heading="完整目录" />
  </main>
</BaseLayout>
