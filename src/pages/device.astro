---
import BaseLayout from "../layouts/BaseLayout.astro";

const session = Astro.url.searchParams.get("session");
const code = Astro.url.searchParams.get("code");
const done = Astro.url.searchParams.get("done");
const error = Astro.url.searchParams.get("error");
const apiOrigin = Astro.url.origin;
---

<BaseLayout title="SkillFlux 设备授权" description="在浏览器中完成 SkillFlux 设备登录。">
  <main class="device-page">
    <h1>SkillFlux 设备授权</h1>

    {done ? (
      <p class="ok">登录完成。请回到你的 agent，再次运行 <code>auth.status</code>。</p>
    ) : error ? (
      <p class="err">授权失败：{error}</p>
    ) : session && code ? (
      <>
        <p>设备码：<strong>{code}</strong></p>
        <p>确认这是你发起的登录请求，然后选择登录方式：</p>
        <div class="actions">
          <a class="button primary" href={`${apiOrigin}/api/auth/github/start?session=${encodeURIComponent(session)}`}>
            使用 GitHub 登录
          </a>
          <a class="button" href={`${apiOrigin}/api/auth/callback/fixture?session=${encodeURIComponent(session)}`}>
            Fixture 登录（开发）
          </a>
        </div>
      </>
    ) : (
      <p>缺少 session 参数。请从 agent 内的 SkillFlux 登录链接进入此页。</p>
    )}
  </main>
</BaseLayout>

<style>
  .device-page {
    max-width: 42rem;
    margin: 4rem auto;
    padding: 0 1rem;
    line-height: 1.6;
  }
  .actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 1.5rem;
  }
  .button {
    display: inline-block;
    padding: 0.6rem 1rem;
    border-radius: 0.5rem;
    border: 1px solid #ccc;
    text-decoration: none;
    color: inherit;
  }
  .button.primary {
    background: #111;
    color: #fff;
    border-color: #111;
  }
  .ok { color: #067647; }
  .err { color: #b42318; }
  code {
    background: #f4f4f5;
    padding: 0.1rem 0.35rem;
    border-radius: 0.25rem;
  }
</style>
